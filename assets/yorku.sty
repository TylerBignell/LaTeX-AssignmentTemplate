\usepackage{amsthm} % AMS theorem boxes
% PLAIN (Theorem, Lemma, Proposition, Corollary, Conjecture, Axiom) ---
\newtheoremstyle{plain} % name
{0.75em}   % Space above
{0.75em}   % Space below
{\itshape} % Body font
{}         % Indent
{\bfseries\color{facultycolour}} % Head font
{:}        % Punctuation after theorem head
{0.5em}    % Space after theorem head
{}         % Head spec
% DEFINITION (Definition, Example, Criterion) -------------
\newtheoremstyle{definition}
{0.75em}
{0.75em}
{}
{}
{\bfseries\color{facultycolour}}
{:}
{0.5em}
{}
% REMARK (Remark, Note) -----------------------------------
\newtheoremstyle{remark}
{0.75em}
{0.75em}
{}
{}
{\bfseries\color{facultycolour!70}}
{:}
{0.5em}
{}
% APPLY STYLES AND DEFINE ENVIRONMENTS --------------------
% Plain
\theoremstyle{plain}
\ifthenelse{\equal{\metaNumberTheorems}{true}}{%
	\newtheorem{theorem}{Theorem}[section]%
	\newtheorem{lemma}{Lemma}[section]%
	\newtheorem{proposition}{Proposition}[section]%
	\newtheorem{corollary}{Corollary}[section]%
	\newtheorem{conjecture}{Conjecture}[section]%
	\newtheorem{axiom}{Axiom}[section]%
}{%
	\newtheorem{theorem}{Theorem}%
	\newtheorem{lemma}{Lemma}%
	\newtheorem{proposition}{Proposition}%
	\newtheorem{corollary}{Corollary}%
	\newtheorem{conjecture}{Conjecture}%
	\newtheorem{axiom}{Axiom}%
}
% Definition
\theoremstyle{definition}
\ifthenelse{\equal{\metaNumberTheorems}{true}}{%
	\newtheorem{definition}{Definition}[section]%
	\newtheorem{example}{Example}[section]%
	\newtheorem{criterion}{Criterion}[section]%
}{%
	\newtheorem{definition}{Definition}%
	\newtheorem{example}{Example}%
	\newtheorem{criterion}{Criterion}%
}
% Remark
\theoremstyle{remark}
\ifthenelse{\equal{\metaNumberTheorems}{true}}{%
	\newtheorem{remark}{Remark}[section]%
	\newtheorem{note}{Note}[section]%
}{%
	\newtheorem{remark}{Remark}%
	\newtheorem{note}{Note}%
}
% PROOF ENVIRONMENT ---------------------------------------
\renewcommand{\qedsymbol}{$\color{facultycolour}\blacksquare$} % QED symbol
\makeatletter
\renewenvironment{proof}[1][\proofname]{%
	\par\pushQED{\qed}%
	\normalfont\topsep0.75em\relax
	\trivlist\item[\hskip\labelsep\bfseries\color{facultycolour}#1\@addpunct{:}]\ignorespaces
}{%
	\popQED\endtrivlist\@endpefalse
}
\makeatother

