%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% PROBLEM / SOLUTION ENVIRONMENTS
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
\usepackage{tcolorbox} % Colored and framed boxes, used for problem/solution environments
\tcbuselibrary{most}   % Loads most tcolorbox libraries (skins, breakable, etc.)
% COUNTER (RESETS EACH SECTION OR SIMPLE) -----------------
\ifthenelse{\equal{\metaNumberProblems}{true}}{%
	\newcounter{problem}[section]%
	\renewcommand{\theproblem}{\thesection.\arabic{problem}}%
}{%
	\newcounter{problem}%
	\renewcommand{\theproblem}{\arabic{problem}}%
}
% PROBLEM BOX ---------------------------------------------
\newenvironment{problem}[1][]{%
	\refstepcounter{problem}%
	\begin{tcolorbox}[
		enhanced,
		breakable,
		colback=white,
		colframe=facultycolour,
		colbacktitle=facultycolour,
		coltitle=white,
		fonttitle=\bfseries,
		title={Problem~\theproblem\ifthenelse{\equal{#1}{}}{}{:~#1}},
		sharp corners,
		toptitle=6pt,
		bottomtitle=6pt,
		lefttitle=10pt,
		leftrule=3pt,
		rightrule=1pt,
		toprule=1pt,
		bottomrule=1pt,]}{%
\end{tcolorbox}}
% SOLUTION BOX --------------------------------------------
\newenvironment{solution}{%
	\begin{tcolorbox}[
		enhanced,
		breakable,
		colback=white,
		colframe=facultycolour,
		fonttitle=\bfseries,
		title={Solution},
		coltitle=facultycolour,
		attach title to upper={\par\vspace{2pt}},
		sharp corners,
		leftrule=3pt,
		rightrule=1pt,
		toprule=1pt,
		bottomrule=1pt,]}{%
\end{tcolorbox}}

