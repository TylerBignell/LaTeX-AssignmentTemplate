% SET THEME COLOUR ----------------------------------------
\ifx\metaThemeColour\empty
\colorlet{themecolour}{DefaultBlue}%
\else
\StrLeft{\metaThemeColour}{1}[\@firstchar]% Get the first character
\if#\@firstchar
% If it starts with #, treat as HTML hex (removing the # for xcolor)
\StrGobbleLeft{\metaThemeColour}{1}[\@hexpure]%
\definecolor{themecolour}{HTML}{\@hexpure}%
