\usepackage{fancyhdr} % Custom headers and footers (\lhead, \rhead, \cfoot, etc.)
% Robust Acronym Generator
\newcommand{\makeAcronym}[1]{%
	\gdef\tempAcro{}%
	% Substitute spaces with commas
	\StrSubstitute{#1}{ }{,}[\tempStepOne]%
	% Substitute hyphens with commas so "Object-Oriented" becomes two words
	\StrSubstitute{\tempStepOne}{-}{,}[\commaName]%
	\foreach \word in \commaName {%
		\IfSubStr{:a:an:the:and:or:for:of:to:in:at:on:by:with:is:as:via:per:A:An:The:And:Or:For:Of:To:In:At:On:By:With:Is:As:Via:Per:}{:\word:}{}{%
			\StrLeft{\word}{1}[\firstL]%
			\xdef\tempAcro{\tempAcro\MakeUppercase{\firstL}}%
		}%
	}%
	\tempAcro%
}
% SMART LEFT HEADER (Collision Detection)
\newcommand{\smartleftheader}{%
	% Measure the Right Side (Student info)
	\sbox2{\ifx\metaPartners\empty\metaStudentName\ifx\metaStudentNumber\empty\else\ (\metaStudentNumber)\fi\fi}%
	% Measure Left Side Variants
	\sbox0{\metaCourseCode: \metaCourseName}% Full
	\sbox1{\metaCourseCode: \makeAcronym{\metaCourseName}}% Acronym
	\sbox3{\metaCourseCode}% Code Only
	% Compare widths against total header width (allowing 5% margin)
	\ifdim \dimexpr\wd0 + \wd2\relax < 0.95\headwidth
	\metaCourseCode: \metaCourseName
	\else
	\ifdim \dimexpr\wd1 + \wd2\relax < 0.95\headwidth
	\metaCourseCode: \makeAcronym{\metaCourseName}
	\else
	\ifdim \dimexpr\wd3 + \wd2\relax < 0.95\headwidth
	\metaCourseCode
	\else
	\relax % If right side is so long it hits even the code, hide left side
	\fi
	\fi
	\fi
}

