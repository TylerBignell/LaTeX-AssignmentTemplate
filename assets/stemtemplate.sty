\colorlet{citecolour}{themecolour}%
\else
\StrLen{\metaCiteColour}[\@citelen]%
\ifnum\@citelen=6
\definecolor{citecolour}{HTML}{\metaCiteColour}%
\else
\colorlet{citecolour}{\metaCiteColour}%
\fi
\fi
% SET URL COLOUR ------------------------------------------
